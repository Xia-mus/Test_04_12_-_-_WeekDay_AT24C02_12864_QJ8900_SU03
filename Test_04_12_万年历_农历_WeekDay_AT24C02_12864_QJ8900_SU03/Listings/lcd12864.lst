  90          void IntToStr(int num, char *str, int digits) //将数字转化为字符，以支持数字的动态显示
  91          {
  92   1        int i = 0;
  93   1        int isNegative = 0;
  94   1        int start, end;
  95   1        int len = 0;
  96   1        int temp = num;
  97   1      
  98   1        // 处理负数
  99   1        if (num < 0) 
 100   1        {
 101   2          isNegative = 1;
 102   2          num = -num;
 103   2          temp = num;
 104   2        }
 105   1      
 106   1        // 计算数字长度
 107   1        do 
 108   1        {
 109   2          len++;
 110   2          temp /= 10;
 111   2        } while (temp != 0);
 112   1      
 113   1        // 如果需要固定位数且实际位数不足，前面补零
 114   1        if (digits > 0 && len < digits) 
 115   1        {
 116   2          for (i = 0; i < digits - len; i++) 
C51 COMPILER V9.57.0.0   LCD12864                                                          05/06/2026 19:51:25 PAGE 3   

 117   2          {
 118   3            str[i] = '0';
 119   3          }
 120   2        }
 121   1      
 122   1        // 处理0的情况
 123   1        if (num == 0) 
 124   1        {
 125   2          if (digits <= 0) 
 126   2          {
 127   3            str[i++] = '0';
 128   3          } 
 129   2          else                      // 如果要求固定位数，0已经通过前面的补零处理了
 130   2          {
 131   3            
 132   3            i = digits - 1;
 133   3            str[i] = '0';
 134   3          }
 135   2        } 
 136   1        else                        // 将数字转换为字符（反向）
 137   1        {                         
 138   2          temp = num;
 139   2          do 
 140   2          {
 141   3            str[i++] = (temp % 10) + '0';
 142   3            temp /= 10;
 143   3          } while (temp != 0);
 144   2        }
 145   1      
 146   1        // 处理负数
 147   1        if (isNegative) 
 148   1        {
 149   2          str[i++] = '-';
 150   2        }
 151   1      
 152   1        // 反转字符串
 153   1        start = (digits > 0 && digits > len) ? digits - len : 0;
 154   1        end = i - 1;
 155   1        while (start < end) 
 156   1        {
 157   2          char temp_char = str[start];
 158   2          str[start] = str[end];
 159   2          str[end] = temp_char;
 160   2          start++;
 161   2          end--;
 162   2        }
 163   1      
 164   1        str[i] = '\0';                        // 添加字符串结束符
 165   1      }
