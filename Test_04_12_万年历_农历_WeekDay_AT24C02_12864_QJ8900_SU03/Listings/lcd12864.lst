   3          void LCD12864_Delay1ms(uint c)              //内置软件延时
   4          {
   5   1        char a,b;
   6   1        for(; c>0; c--)
   7   1        {
   8   2          for(b=199; b>0; b--)
   9   2          {
  10   3                for(a=1; a>0; a--);
  11   3          }
  12   2        }
  13   1      }
