 167          void IntToStr2Digit(int num, char *str) //将数字转化为两位数字符串，不足两位前面补零
 168          {
 169   1        // 确保数字在0-99范围内
 170   1        if (num < 0) num = 0;
 171   1        if (num > 99) num = 99;
 172   1        
 173   1        // 转换为两位数字符串
 174   1        str[0] = (num / 10) + '0';
 175   1        str[1] = (num % 10) + '0';
 176   1        str[2] = '\0'; // 字符串结束符
 177   1      }
