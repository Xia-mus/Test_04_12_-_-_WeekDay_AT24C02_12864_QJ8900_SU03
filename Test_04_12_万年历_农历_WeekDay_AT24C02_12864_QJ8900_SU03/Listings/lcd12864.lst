 179          void LCD12864_Init()                    //初始化LCD12864
 180          {
 181   1        LCD12864_PSB = 1;                     //选择并行输入
 182   1        LCD12864_RST = 1;                     //复位
 183   1      
 184   1        LCD12864_WriteCmd(0x30);              //选择基本指令操作
 185   1        LCD12864_WriteCmd(0x0c);              //显示开，关光标
 186   1        LCD12864_WriteCmd(0x01);              //清除LCD12864的显示内容
 187   1      }
 188          
 189          void LCD12864_SetWindow(uchar x, uchar y, uchar *word)//设置在基本指令模式下设置显示坐标，并显示汉字。注意
             -：x是设置行，y是设置列
 190          {
 191   1        uchar pos;
 192   1        uchar i = 0;                          // 从字符串的第一个字符开始显示
 193   1      
 194   1        // 设置行地址
 195   1        if(x == 0) pos = 0x80 + y;            // 第一行的地址是80H
 196   1        else if(x == 1) pos = 0x90 + y;       // 第二行的地址是90H
 197   1        else if(x == 2) pos = 0x88 + y;       // 第三行的地址是88H
 198   1        else if(x == 3) pos = 0x98 + y;       // 第四行的地址是98H
 199   1        else return;                          // 行错误，直接返回
 200   1                    
 201   1        LCD12864_WriteCmd(pos);               // 设置光标位置
 202   1      
 203   1        // 显示字符串，直到字符串结束或者超出本行（一行最多16个字符，从y列开始，所以最多显示16-y个字符）
 204   1        while (word[i] != '\0' && y < 16) 
 205   1        {
 206   2          LCD12864_WriteData(word[i]);
 207   2          i++;
 208   2          y++;                                // 列位置增加，同时也可以用来判断是否超出本行
 209   2        }
 210   1      }
 211          
 212          void LCD12864_ShowNumber(uchar x, uchar y, int number)  //显示数字的函数
 213          {
 214   1        char buffer[16];                                      // 缓冲区，用于存储转换后的字符串
 215   1        IntToStr(number, buffer,2);                           // 转换数字为字符串
 216   1        LCD12864_SetWindow(x, y, (uchar *)buffer);            // 调用现有的显示函数
 217   1      }
 218          
 219          void LCD12864_Show2DigitNumber(uchar x, uchar y, int number) //显示两位数字的函数（适用于时钟显示）
 220          {
 221   1          char buffer[3];                                     // 缓冲区，用于存储两位数字符串
 222   1          IntToStr2Digit(number, buffer);                     // 转换数字为两位数字符串
 223   1          LCD12864_SetWindow(x, y, (uchar *)buffer);
 224   1      }


