  15          uchar LCD12864_Busy(void)                   //检测LCD是否忙（1表示不忙，0表示忙）
  16          {
  17   1        uchar i = 0;
  18   1      
  19   1        LCD12864_RS = 0;                          //选择命令
  20   1        LCD12864_RW = 1;                          //选择读取
  21   1      
  22   1        LCD12864_EN = 1;
  23   1        LCD12864_Delay1ms(1);
  24   1      
  25   1        while((LCD12864_DATAPORT & 0x80) == 0x80) //检测读取到的值
  26   1        {
  27   2          i++;
  28   2          if(i > 100)
  29   2          {
  30   3            LCD12864_EN = 0;
  31   3            return 0;                             //超过等待时间返回0表示失败
  32   3          }
  33   2        }
  34   1      
  35   1        LCD12864_EN = 0;
  36   1      
  37   1        return 1;
  38   1      }
