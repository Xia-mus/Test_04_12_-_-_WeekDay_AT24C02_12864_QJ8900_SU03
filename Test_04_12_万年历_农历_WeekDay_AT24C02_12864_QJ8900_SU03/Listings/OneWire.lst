   1          #include <REGX52.H>
   2          
   3          sbit OneWire_DQ=P3^7;
   4          
   5          //单总线初始化（复位脉冲 + 存在检测）
   6          unsigned char OneWire_Init(void)
   7          {
   8   1        unsigned char i;
   9   1        unsigned char AckBit;
  10   1        EA=0;                   // 禁用总中断，确保时序精确
  11   1        OneWire_DQ=1;           // 确保总线为高电平
  12   1        OneWire_DQ=0;           // 主机拉低总线，开始复位脉冲
  13   1        i = 247;while (--i);    //Delay 500us
  14   1        OneWire_DQ=1;           // 主机释放总线，由上拉电阻拉高
  15   1        i = 32;while (--i);     //Delay 70us
  16   1        AckBit=OneWire_DQ;      // 采样存在脉冲：0-设备存在，1-无设备
  17   1        i = 247;while (--i);    //Delay 500us
  18   1        EA=1;                   // 重新启用总中断
  19   1        return AckBit;
  20   1      }
  21          
  22          /**
  23            * @brief  单总线发送一位
  24            * @param  Bit 要发送的位
  25            * @retval 无
  26            */
  27          void OneWire_SendBit(unsigned char Bit)
  28          {
  29   1        unsigned char i;
  30   1        EA=0;
  31   1        OneWire_DQ=0;
  32   1        i = 4;while (--i);      //Delay 10us
  33   1        OneWire_DQ=Bit;
  34   1        i = 24;while (--i);     //Delay 50us
  35   1        OneWire_DQ=1;
  36   1        EA=1;
  37   1      }
  38          
  39          /**
  40            * @brief  单总线接收一位
  41            * @param  无
  42            * @retval 读取的位
  43            */
  44          unsigned char OneWire_ReceiveBit(void)
  45          {
  46   1        unsigned char i;
  47   1        unsigned char Bit;
  48   1        EA=0;
  49   1        OneWire_DQ=0;
  50   1        i = 2;while (--i);      //Delay 5us
  51   1        OneWire_DQ=1;
  52   1        i = 2;while (--i);      //Delay 5us
  53   1        Bit=OneWire_DQ;
  54   1        i = 24;while (--i);     //Delay 50us
C51 COMPILER V9.57.0.0   ONEWIRE                                                           05/06/2026 19:51:26 PAGE 2   

  55   1        EA=1;
  56   1        return Bit;
  57   1      }
  58          
  59          /**
  60            * @brief  单总线发送一个字节
  61            * @param  Byte 要发送的字节
  62            * @retval 无
  63            */
  64          void OneWire_SendByte(unsigned char Byte)
  65          {
  66   1        unsigned char i;
  67   1        for(i=0;i<8;i++)
  68   1        {
  69   2          OneWire_SendBit(Byte&(0x01<<i));
  70   2        }
  71   1      }
  72          
  73          /**
  74            * @brief  单总线接收一个字节
  75            * @param  无
  76            * @retval 接收的一个字节
  77            */
  78          unsigned char OneWire_ReceiveByte(void)
  79          {
  80   1        unsigned char i;
  81   1        unsigned char Byte=0x00;
  82   1        for(i=0;i<8;i++)
  83   1        {
  84   2          if(OneWire_ReceiveBit()){Byte|=(0x01<<i);}
  85   2        }
  86   1        return Byte;
  87   1      }


